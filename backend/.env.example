# PostgreSQL — Railway provides this automatically when you add a Postgres service
DATABASE_URL=postgresql://user:password@host:5432/opportubot

# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# Your email — this account gets owner/admin access automatically
OWNER_EMAIL=your@email.com

# Get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
